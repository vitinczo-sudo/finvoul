{
  "name": "finvault-api",
  "version": "1.0.0",
  "description": "FinVault — API Financeira Segura",
  "main": "server.js",
  "scripts": {
    "start":     "node server.js",
    "dev":       "nodemon server.js",
    "test":      "jest --runInBand --forceExit",
    "test:cov":  "jest --coverage",
    "migrate":   "psql $DATABASE_URL -f schema.sql",
    "keygen":    "node scripts/keygen.js",
    "lint":      "eslint . --ext .js"
  },
  "engines": { "node": ">=20.0.0" },
  "dependencies": {
    "argon2":               "^0.31.2",
    "compression":          "^1.7.4",
    "cors":                 "^2.8.5",
    "express":              "^5.0.1",
    "express-rate-limit":   "^7.4.1",
    "express-slow-down":    "^2.0.3",
    "google-auth-library":  "^9.14.2",
    "helmet":               "^8.0.0",
    "ioredis":              "^5.4.1",
    "joi":                  "^17.13.3",
    "jsonwebtoken":         "^9.0.2",
    "morgan":               "^1.10.0",
    "pg":                   "^8.13.1",
    "speakeasy":            "^2.0.0"
  },
  "devDependencies": {
    "jest":                 "^29.7.0",
    "supertest":            "^7.0.0",
    "nodemon":              "^3.1.7",
    "@eslint/js":           "^9.15.0",
    "eslint":               "^9.15.0"
  }
}
