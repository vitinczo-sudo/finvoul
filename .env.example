# ══════════════════════════════════════════════
# FinVault — Variáveis de Ambiente
# COPIE para .env e preencha TODOS os valores
# NUNCA commite .env no git!
# ══════════════════════════════════════════════

# ── App
NODE_ENV=production
PORT=3001
APP_URL=https://seudominio.com.br
DOMAIN=seudominio.com.br

# ── Database PostgreSQL
DB_PASS=GERE_COM_openssl_rand_base64_32
DATABASE_URL=postgres://finvault_app:SEU_DB_PASS@postgres:5432/finvault

# ── Redis
REDIS_PASS=GERE_COM_openssl_rand_base64_32
REDIS_URL=redis://:SEU_REDIS_PASS@redis:6379

# ── JWT RS256 (gere com: node scripts/keygen.js)
# Coloque a chave privada com \n substituindo quebras de linha
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_EXPIRES=15m
REFRESH_EXPIRES=30d

# ── Criptografia AES-256-GCM (32 bytes em hex)
# Gere com: openssl rand -hex 32
AES_KEY=SUBSTITUA_POR_64_CHARS_HEX_ALEATORIOS

# ── Google OAuth
# Console: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=XXXXXXXX.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-XXXXXXXXX

# ── E-mail (SendGrid ou Resend)
SENDGRID_API_KEY=SG.XXXXXXXXXX
EMAIL_FROM=noreply@seudominio.com.br
EMAIL_FROM_NAME=FinVault

# ── Backup S3/R2
BACKUP_S3_KEY=SEU_ACCESS_KEY
BACKUP_S3_SECRET=SEU_SECRET_KEY
BACKUP_S3_BUCKET=finvault-backups

# ── Monitoramento (opcional mas recomendado)
SENTRY_DSN=https://XXXXXX@o0.ingest.sentry.io/0
DATADOG_API_KEY=SEU_DD_KEY

# ── Open Banking (Pluggy API — https://pluggy.ai)
PLUGGY_CLIENT_ID=SEU_PLUGGY_ID
PLUGGY_CLIENT_SECRET=SEU_PLUGGY_SECRET

# ── Rate Limiting
MAX_LOGIN_FAILS=5
LOCKOUT_MINUTES=30
